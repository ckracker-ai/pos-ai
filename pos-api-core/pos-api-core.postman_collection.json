    {
      "name": "Empresas",
      "item": [
        {
          "name": "POST /empresas (onboarding + admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('onboarding 201 o RUT duplicado', function () {",
                  "  pm.expect([201, 409]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json().data;",
                  "  if (data.empresa) pm.collectionVariables.set('empresaId', data.empresa.id);",
                  "  if (data.branch) pm.collectionVariables.set('branchId', data.branch.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-internal-key", "value": "{{keyInternal}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rut\": \"76.999.888-8\",\n  \"razonSocial\": \"QA Tenant SpA\",\n  \"nombreFantasia\": \"QA Tenant\",\n  \"branchName\": \"Sucursal QA\",\n  \"adminEmail\": \"qa.admin@qatenant.cl\",\n  \"adminPassword\": \"Str0ngPass!123\",\n  \"adminFullName\": \"Admin QA\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/empresas",
              "host": ["{{baseUrl}}"],
              "path": ["empresas"]
            }
          },
          "response": []
        },
        {
          "name": "POST /auth/login (admin QA tenant)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('token present', () => !!pm.response.json().data.token);",
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json().data;",
                  "  if (data.token) pm.collectionVariables.set('token', data.token);",
                  "  if (data.user) {",
                  "    pm.collectionVariables.set('userId', data.user.id);",
                  "    pm.collectionVariables.set('empresaId', data.user.empresaId);",
                  "    pm.collectionVariables.set('branchId', data.user.branchId);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"qa.admin@qatenant.cl\",\n  \"password\": \"Str0ngPass!123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        },
