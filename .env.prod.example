# Copiar a .env.prod antes del despliegue en VPS:
#   cp .env.prod.example .env.prod

# --- Dominios (cuando los tengas) ---
APP_DOMAIN=app.tudominio.com
API_DOMAIN=api.tudominio.com

# Vacío = el frontend usa /api vía Nginx (mismo origen, recomendado)
# Si prefieres API en subdominio separado:
# NEXT_PUBLIC_API_URL=https://api.tudominio.com
NEXT_PUBLIC_API_URL=

# auto | on | off
# auto = HTTPS si existen certs en nginx/certs/live/<dominio>/
SSL_MODE=auto

# true = certificados de prueba Let's Encrypt (staging)
CERTBOT_STAGING=false
CERTBOT_EMAIL=admin@tudominio.com

NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# --- Secretos (cambiar en producción) ---
INTERNAL_API_KEY=supersecretkey
JWT_SECRET=svm_jwt_secret_key_2026
JWT_REFRESH_SECRET=svm_jwt_refresh_secret_2026

# Admin bootstrap inicial
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_EMAIL=admin@empanadascostaazul.cl
BOOTSTRAP_ADMIN_PASSWORD=@dmin123_
BOOTSTRAP_ADMIN_FULL_NAME=Administrador Costa Azul
BOOTSTRAP_ADMIN_BRANCH_NAME=Sucursal Central
BOOTSTRAP_ADMIN_RESET_PASSWORD=false

# MySQL
MYSQL_ROOT_PASSWORD=cambiar_root_seguro
MYSQL_DATABASE=erp_core_db
MYSQL_USER=usr_erp
MYSQL_PASSWORD=cambiar_password_seguro
