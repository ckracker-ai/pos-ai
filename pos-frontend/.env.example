# Dejar vacío en Docker (rewrite vía Next → BFF interno).
# Dev directo al BFF: http://localhost:2020
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_AUTH_URL=

# Next server → BFF (Docker compose / local)
BFF_INTERNAL_URL=http://localhost:2020
AUTH_URL=http://localhost:2020

NEXT_PUBLIC_DEFAULT_BRANCH_ID=1
NODE_ENV=development

# Rutas API: /pos/proxy/auth/login, /pos/proxy/catalog/...

# Landing — correo del formulario de contacto (mailto)
NEXT_PUBLIC_CONTACT_EMAIL=contacto@pos-ai.local
